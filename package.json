{
  "name": "ufc-tactical-dashboard",
  "version": "3.6.0",
  "description": "UFC Tactical Analysis Dashboard — SQLite API + Three.js 3D + biomechanics framework",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "test": "node tests/run.js",
